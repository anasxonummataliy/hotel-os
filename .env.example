# ══════════════════════════════════════════════════════════════
# HotelOS — Muhit Sozlamalari Namunasi
# .env faylini shu asosda yarating
# ══════════════════════════════════════════════════════════════

# PostgreSQL ma'lumotlar bazasi
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hotel_os

# JWT autentifikatsiya kaliti (ishlab chiqarishda o'zgartiring!)
SECRET_KEY=your-secret-key-here

# Redis (xabar brokeri — Pub/Sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Servis portlari
AUTH_SERVICE_PORT=8000
RECEPTION_SERVICE_PORT=8001
HOUSEKEEPING_SERVICE_PORT=8002
ROOM_SERVICE_PORT=8003
MAINTENANCE_SERVICE_PORT=8004
WEBSOCKET_GATEWAY_PORT=8005

# Ilova sozlamalari
DEBUG=False
ENVIRONMENT=production
